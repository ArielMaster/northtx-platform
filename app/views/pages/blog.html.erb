<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:max-w-4xl">
      <h2 class="text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl">
        From the blog
      </h2>
      <p class="mt-2 text-lg/8 text-gray-600">
        Insights on operations, scheduling, automation, and building modern service‑based businesses.
      </p>

      <div class="mt-16 space-y-20 lg:mt-20">

        <!-- Article 1 -->
        <article class="relative isolate flex flex-col gap-8 lg:flex-row">
          <div class="relative aspect-video sm:aspect-2/1 lg:aspect-square lg:w-64 lg:shrink-0">
            <img src="https://images.unsplash.com/photo-1496128858413-b36217c2ce36?auto=format&fit=crop&w=3603&q=80"
                 alt="" class="absolute inset-0 size-full rounded-2xl bg-gray-50 object-cover" />
            <div class="absolute inset-0 rounded-2xl inset-ring inset-ring-gray-900/10"></div>
          </div>

          <div>
            <div class="flex items-center gap-x-4 text-xs">
              <time datetime="2020-03-16" class="text-gray-500">Mar 16, 2020</time>
              <%= link_to "Clinic Operations", essential_tips_path, class: "font-semibold read-more text-gray-800 hover:text-gray-500" %>
            </div>

            <div class="group relative max-w-xl">
              <h3 class="mt-3 text-lg/6 font-semibold text-sky-500 group-hover:text-sky-300">
                <%= link_to "5 Ways Clinics Can Automate Client Intake", essential_tips_path %>
              </h3>
              <p class="mt-5 text-sm/6 text-gray-600">
                Learn how clinics can streamline patient intake, reduce manual work, and improve accuracy using automated submissions, routing, and bilingual workflows.
              </p>
            </div>

            <div class="mt-6 flex border-t border-gray-900/5 pt-6">
              <div class="relative flex items-center gap-x-4">
                <img src="https://images.unsplash.com/photo-1519244703995-f4e0f30006d5?auto=format&fit=facearea&facepad=2&w=256&h=256&q=80"
                     alt="" class="size-10 rounded-full bg-gray-50" />
                <div class="text-sm/6">
                  <p class="font-semibold text-gray-900 hover:text-gray-600">Michael Foster</p>
                  <p class="text-gray-600">Product Engineer, Clinic Platform</p>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Article 2 -->
        <article class="relative isolate flex flex-col gap-8 lg:flex-row">
          <div class="relative aspect-video sm:aspect-2/1 lg:aspect-square lg:w-64 lg:shrink-0">
            <img src="https://images.unsplash.com/photo-1547586696-ea22b4d4235d?auto=format&fit=crop&w=3270&q=80"
                 alt="" class="absolute inset-0 size-full rounded-2xl bg-gray-50 object-cover" />
            <div class="absolute inset-0 rounded-2xl inset-ring inset-ring-gray-900/10"></div>
          </div>

          <div>
            <div class="flex items-center gap-x-4 text-xs">
              <time datetime="2020-03-10" class="text-gray-500">Mar 10, 2020</time>
              <%= link_to "Design & UX", importance_ui_path, class: "font-semibold read-more text-gray-800 hover:text-gray-500" %>
            </div>

            <div class="group relative max-w-xl">
              <h3 class="mt-3 text-lg/6 font-semibold text-sky-500 group-hover:text-sky-300">
                <%= link_to "Why UI Matters for Service‑Based Businesses", importance_ui_path %>
              </h3>
              <p class="mt-5 text-sm/6 text-gray-600">
                A clean, intentional interface improves staff efficiency, reduces errors, and creates a better experience for clients across both Clinic and Commercial Platforms.
              </p>
            </div>

            <div class="mt-6 flex border-t border-gray-900/5 pt-6">
              <div class="relative flex items-center gap-x-4">
                <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=facearea&facepad=2&w=256&h=256&q=80"
                     alt="" class="size-10 rounded-full bg-gray-50" />
                <div class="text-sm/6">
                  <p class="font-semibold text-gray-900 hover:text-gray-600">Lindsay Walton</p>
                  <p class="text-gray-600">Lead UI/UX Designer</p>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Article 3 -->
        <article class="relative isolate flex flex-col gap-8 lg:flex-row">
          <div class="relative aspect-video sm:aspect-2/1 lg:aspect-square lg:w-64 lg:shrink-0">
            <img src="https://images.unsplash.com/photo-1492724441997-5dc865305da7?auto=format&fit=crop&w=3270&q=80"
                 alt="" class="absolute inset-0 size-full rounded-2xl bg-gray-50 object-cover" />
            <div class="absolute inset-0 rounded-2xl inset-ring inset-ring-gray-900/10"></div>
          </div>

          <div>
            <div class="flex items-center gap-x-4 text-xs">
              <time datetime="2020-02-12" class="text-gray-500">Feb 12, 2020</time>
              <%= link_to "Commercial Insights", e_commerce_path, class: "font-semibold read-more text-gray-800 hover:text-gray-500" %>
            </div>

            <div class="group relative max-w-xl">
              <h3 class="mt-3 text-lg/6 font-semibold text-sky-500 group-hover:text-sky-300">
                <%= link_to "How Commercial Teams Can Streamline Bookings", e_commerce_path %>
              </h3>
              <p class="mt-5 text-sm/6 text-gray-600">
                Explore how barbershops, studios, and service businesses can simplify bookings, reduce no‑shows, and improve staff coordination using our Commercial Platform.
              </p>
            </div>

            <div class="mt-6 flex border-t border-gray-900/5 pt-6">
              <div class="relative flex items-center gap-x-4">
                <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=facearea&facepad=2&w=256&h=256&q=80"
                     alt="" class="size-10 rounded-full bg-gray-50" />
                <div class="text-sm/6">
                  <p class="font-semibold text-gray-900 hover:text-gray-600">Tom Cook</p>
                  <p class="text-gray-600">Director, Commercial Platform</p>
                </div>
              </div>
            </div>
          </div>
        </article>

      </div>
    </div>
  </div>
</div>
