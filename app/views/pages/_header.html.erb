<!-- Include this script tag or install `@tailwindplus/elements` via npm: -->
<!-- <script src="https://cdn.jsdelivr.net/npm/@tailwindplus/elements@1" type="module"></script> -->
<header class="bg-white">
  <nav aria-label="Global" class="flex justify-between p-4 lg:px-8">
    
      <%= link_to root_path, class: "font-bold text-lg text-gray-800" do %>NORTH<span class="text-sky-500">TX</span> <% end %>
    
    <div class="flex lg:hidden">
      <button type="button" command="show-modal" commandfor="mobile-menu" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-sky-500">
        <span class="sr-only">Open main menu</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-7">
          <path d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-6">
      <%= link_to "Home", home_path, class: "link-underline relative px-0 text-sm/6 text-gray-900 hover:text-sky-500
          after:absolute after:left-0 after:-bottom-0.5 after:h-[2px]
          after:w-0 after:bg-sky-500 after:transition-all after:duration-300
          hover:after:w-full" %>
      <%= link_to "About", about_path, class: "link-underline relative px-0 text-sm/6 text-gray-900 hover:text-sky-500
          after:absolute after:left-0 after:-bottom-0.5 after:h-[2px]
          after:w-0 after:bg-sky-500 after:transition-all after:duration-300
          hover:after:w-full" %>
      <%= link_to "Services", services_path, class: "link-underline relative px-0 text-sm/6 text-gray-900 hover:text-sky-500
          after:absolute after:left-0 after:-bottom-0.5 after:h-[2px]
          after:w-0 after:bg-sky-500 after:transition-all after:duration-300
          hover:after:w-full" %>
      <%= link_to "Portfolio", portfolio_path, class: "link-underline relative px-0 text-sm/6 text-gray-900 hover:text-sky-500
          after:absolute after:left-0 after:-bottom-0.5 after:h-[2px]
          after:w-0 after:bg-sky-500 after:transition-all after:duration-300
          hover:after:w-full" %>
      <%= link_to "Pricing", pricing_path, class: "link-underline relative px-0 text-sm/6 text-gray-900 hover:text-sky-500
          after:absolute after:left-0 after:-bottom-0.5 after:h-[2px]
          after:w-0 after:bg-sky-500 after:transition-all after:duration-300
          hover:after:w-full" %>
      <%= link_to "Blog", blog_path, class: "link-underline relative px-0 text-sm/6 text-gray-900 hover:text-sky-500
          after:absolute after:left-0 after:-bottom-0.5 after:h-[2px]
          after:w-0 after:bg-sky-500 after:transition-all after:duration-300
          hover:after:w-full" %>
      <%= link_to "Contact", contact_path, class: "link-underline relative px-0 text-sm/6 text-gray-900 hover:text-sky-500
          after:absolute after:left-0 after:-bottom-0.5 after:h-[2px]
          after:w-0 after:bg-sky-500 after:transition-all after:duration-300
          hover:after:w-full" %>
      <% if user_signed_in? %>
        <%= link_to "Sign out", destroy_user_session_path, method: :delete, class: "text-red-600 hover:text-red-800 font-semibold" %>
      <% end %>


      <!--a href="#" class="px-2 text-sm/6 font-semibold text-gray-100 hover:text-amber-400">Log in <span aria-hidden="true">&rarr;</span></a-->
    </div>
  </nav>
  <el-dialog>
    <dialog id="mobile-menu" class="backdrop:bg-transparent lg:hidden">
      <div tabindex="0" class="fixed inset-0 focus:outline-none">
        <el-dialog-panel class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-white p-6 sm:max-w-sm sm:ring-1 sm:ring-gray-900/10">
          <div class="flex items-center justify-between">
            <%= link_to root_path, class: "font-bold text-lg text-gray-800" do %>NORTH<span class="text-sky-500">TX</span> <% end %>
            <button type="button" command="close" commandfor="mobile-menu" class="-m-2.5 rounded-md p-2.5 text-sky-500">
              <span class="sr-only">Close menu</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-7">
                <path d="M6 18 18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>
          <div class="mt-6 flow-root">

  <!-- Main Navigation -->
  <div class="-my-6 divide-y divide-gray-200/70">
    <div class="space-y-1 px-3 py-6">
      <%= link_to "Home", home_path,
            class: "-mx-3 block rounded-lg px-3 py-2 text-base text-gray-900 hover:text-sky-500" %>

      <%= link_to "About", about_path,
            class: "-mx-3 block rounded-lg px-3 py-2 text-md text-gray-900 hover:text-sky-500" %>

      <%= link_to "Services", services_path,
            class: "-mx-3 block rounded-lg px-3 py-2 text-md text-gray-900 hover:text-sky-500" %>

      <%= link_to "Portfolio", portfolio_path,
            class: "-mx-3 block rounded-lg px-3 py-2 text-md text-gray-900 hover:text-sky-500" %>

      <%= link_to "Pricing", pricing_path,
            class: "-mx-3 block rounded-lg px-3 py-2 text-md text-gray-900 hover:text-sky-500" %>

      <%= link_to "Blog", blog_path,
            class: "-mx-3 block rounded-lg px-3 py-2 text-md text-gray-900 hover:text-sky-500" %>

      <%= link_to "Contact", contact_path,
            class: "-mx-3 block rounded-lg px-3 py-2 text-md text-gray-900 hover:text-sky-500" %>
    </div>
  </div>

  <!-- Secondary Navigation (Solutions, Support, Legal) -->
  <div class="mt-10 grid grid-cols-2 gap-8 px-3">

    <!-- Column 1 -->
    <div>
      <h3 class="text-sm font-semibold text-gray-900">Solutions</h3>
      <ul class="mt-3 space-y-1.5">
        <li><%= link_to "Analytics", analytics_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>

        <li><%= link_to "Automation", automation_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>

        <li><%= link_to "Commerce", commerce_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>

        <li><%= link_to "Insights", insights_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>
      </ul>

      <h3 class="mt-8 text-sm font-semibold text-gray-900">Support</h3>
      <ul class="mt-3 space-y-1.5">
        <li><%= link_to "Submit ticket", submit_ticket_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>

        <li><%= link_to "Documentation", documentation_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>

        <li><%= link_to "Guides", guides_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>
      </ul>
    </div>

    <!-- Column 2 -->
    <div>
      <h3 class="text-sm font-semibold text-gray-900">Legal</h3>
      <ul class="mt-3 space-y-1.5">
        <li><%= link_to "Terms of service", terms_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>

        <li><%= link_to "Privacy policy", privacy_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>

        <li><%= link_to "License", license_path,
              class: "block rounded-md px-1 py-1.5 text-sm text-gray-600 hover:text-sky-500" %></li>
      </ul>
    </div>

  </div>

</div>

        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>
