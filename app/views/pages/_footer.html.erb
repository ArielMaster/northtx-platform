<footer class="bg-white">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-24 lg:px-8 lg:py-32">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="md:grid md:grid-rows-3 md:gap-2">
        <%= link_to root_path, class: "font-bold text-lg", alt: "Company name" do %>NORTH<span class="text-sky-500">TX</span> <% end %>
          <ul role="list" class="mt-6 flex space-x-12">
            <li>
              <a href="https://facebook.com" class="text-gray-600 hover:text-blue-600">
                <span class="sr-only">Facebook</span>
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-6">
