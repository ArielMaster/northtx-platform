                </svg>
              </a>
            </li>
            <li>
              <a href="https://github.com" class="text-gray-600 hover:text-purple-800">
                <span class="sr-only">GitHub</span>
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-6">
                  <path d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" fill-rule="evenodd" />
                </svg>
              </a>
            </li>
            <li>
              <a href="https://x.com" class="text-gray-600 hover:text-gray-900">
                <span class="sr-only">X</span>
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-6">
                  <path d="M11.4678 8.77491L17.2961 2H15.915L10.8543 7.88256L6.81232 2H2.15039L8.26263 10.8955L2.15039 18H3.53159L8.87581 11.7878L13.1444 18H17.8063L11.4675 8.77491H11.4678ZM9.57608 10.9738L8.95678 10.0881L4.02925 3.03974H6.15068L10.1273 8.72795L10.7466 9.61374L15.9156 17.0075H13.7942L9.57608 10.9742V10.9738Z" />
                </svg>
              </a>
            </li>
          </ul>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm/6 font-semibold text-gray-900">Solutions</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li>
                <%= link_to "Analytics", analytics_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Automation", automation_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Commerce", commerce_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Insights", insights_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm/6 font-semibold text-gray-900">Support</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li>
                <%= link_to "Submit ticket", submit_ticket_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Documentation", documentation_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Guides", guides_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Careers", careers_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
            </ul>
          </div>
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          <div>
            <h3 class="text-sm/6 font-semibold text-gray-900">Company</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li>
                <%= link_to "Home", home_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "About", about_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Services", services_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Portfolio", portfolio_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Pricing", pricing_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Blog", blog_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Contact", contact_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
            </ul>
          </div>
          <div class="mt-10 md:mt-0">
            <h3 class="text-sm/6 font-semibold text-gray-900">Legal</h3>
            <ul role="list" class="mt-6 space-y-4">
              <li>
                <%= link_to "Terms of service", terms_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "Privacy policy", privacy_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
              <li>
                <%= link_to "License", license_path, class: "text-sm/6 text-gray-600 hover:text-sky-500" %>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
