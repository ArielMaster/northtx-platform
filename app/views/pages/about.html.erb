<!-- About Page -->
<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-none">

      <!-- Header -->
      <p class="text-base/7 font-semibold text-sky-500">About Us</p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl">
        Built for Modern Service Businesses
      </h1>

      <!-- Intro -->
      <div class="mt-8 max-w-3xl text-base/7 text-gray-600">
        <p>
          Founded in <strong>April 2020</strong>, our company was created with a simple belief:
          <span class="text-gray-900 font-medium">service‑based businesses deserve software that adapts to them — not the other way around.</span>
        </p>
        <p class="mt-4">
          From clinics to commercial service teams, businesses everywhere struggle with scattered tools, manual workflows, and outdated systems. 
          We set out to change that by building a modern operating system that helps teams run with clarity, speed, and confidence — available in both 
          <strong>English and Spanish</strong> to support diverse staff and clients.
        </p>
      </div>

      <!-- Mission -->
      <div class="mt-12">
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">Our Mission</h2>
        <p class="mt-6 max-w-3xl text-base/7 text-gray-600">
          Our mission is to give service businesses a unified workflow that removes friction and empowers teams to operate at their best.
          We simplify daily operations by centralizing scheduling, submissions, staff coordination, communication, and analytics — all in one platform.
        </p>
      </div>

      <!-- How We Build -->
      <div class="mt-12">
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">How We Build</h2>
        <div class="mt-6 grid grid-cols-1 gap-8 text-base/7 text-gray-600 lg:grid-cols-2">
          <div>
            <p>
              We build with a <strong>production-first mindset</strong>. Every feature is designed to be reliable, secure, and maintainable — not rushed or fragile.
            </p>
            <p class="mt-6">
              Our engineering approach focuses on owning the stack, designing for security, and building for scale. 
              We prioritize performance and reduce complexity so businesses can operate with confidence.
            </p>
          </div>
          <div>
            <ul class="space-y-4 text-gray-700">
              <li class="flex gap-3">
                <span class="text-sky-500 font-bold">•</span> Own the stack — infrastructure to frontend
              </li>
              <li class="flex gap-3">
                <span class="text-sky-500 font-bold">•</span> Security by default — encrypted flows, role‑based access
              </li>
              <li class="flex gap-3">
                <span class="text-sky-500 font-bold">•</span> Built for scale — multi-tenant architecture
              </li>
              <li class="flex gap-3">
                <span class="text-sky-500 font-bold">•</span> Performance matters — fast and predictable
              </li>
              <li class="flex gap-3">
                <span class="text-sky-500 font-bold">•</span> Reduce complexity — simple interfaces, powerful workflows
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Who We Serve -->
      <div class="mt-12">
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">Who We Serve</h2>
        <p class="mt-6 max-w-3xl text-base/7 text-gray-600">
          We support service-based businesses that depend on scheduling, staff coordination, and client communication — including:
        </p>

        <ul class="mt-6 grid grid-cols-1 gap-4 text-gray-700 sm:grid-cols-2 lg:grid-cols-3">
          <li class="flex gap-3"><span class="text-sky-500 font-bold">•</span> Clinics & wellness practices</li>
          <li class="flex gap-3"><span class="text-sky-500 font-bold">•</span> Barbershops & grooming studios (via Commercial Platform)</li>
          <li class="flex gap-3"><span class="text-sky-500 font-bold">•</span> Commercial service businesses</li>
          <li class="flex gap-3"><span class="text-sky-500 font-bold">•</span> Creative studios & agencies</li>
          <li class="flex gap-3"><span class="text-sky-500 font-bold">•</span> Multi-location operations</li>
        </ul>
      </div>

      <!-- Values -->
      <div class="mt-16">
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">Our Values</h2>

        <dl class="mt-10 grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-4">
          <div class="flex flex-col-reverse gap-y-3 border-l border-sky-200 pl-6">
            <dt class="text-base/7 text-gray-600">Clarity over complexity</dt>
            <dd class="text-xl font-semibold tracking-tight text-sky-500">Simplicity</dd>
          </div>

          <div class="flex flex-col-reverse gap-y-3 border-l border-sky-200 pl-6">
            <dt class="text-base/7 text-gray-600">Security by default</dt>
            <dd class="text-xl font-semibold tracking-tight text-sky-500">Trust</dd>
          </div>

          <div class="flex flex-col-reverse gap-y-3 border-l border-sky-200 pl-6">
            <dt class="text-base/7 text-gray-600">Performance matters</dt>
            <dd class="text-xl font-semibold tracking-tight text-sky-500">Speed</dd>
          </div>

          <div class="flex flex-col-reverse gap-y-3 border-l border-sky-200 pl-6">
            <dt class="text-base/7 text-gray-600">Build for the real world</dt>
            <dd class="text-xl font-semibold tracking-tight text-sky-500">Practicality</dd>
          </div>
        </dl>
      </div>

      <!-- Vision -->
      <div class="mt-20">
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">Our Vision</h2>
        <p class="mt-6 max-w-3xl text-base/7 text-gray-600">
          We're building the modern operating system for service businesses — a platform that adapts to the way teams actually work, scales with them, and gives them the clarity to grow.
        </p>
      </div>

      <!-- Bilingual Support -->
      <div class="mt-8">
        <h2 class="text-2xl font-semibold tracking-tight text-gray-900">Global & Bilingual by Design</h2>
        <p class="mt-6 max-w-3xl text-base/7 text-gray-600">
          We support both <strong>English and Spanish</strong> user languages, enabling businesses to serve diverse communities and operate across regions without friction.
          As we continue to expand, multilingual support will remain a core part of our mission to make powerful tools accessible to everyone.
        </p>
      </div>

    </div>
  </div>
</div>

<!--Section-2-->
<div class="bg-sky-500 py-16 sm:py-24 lg:py-32">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-6 lg:grid-cols-12 lg:gap-8 lg:px-8">
    <h2 class="max-w-xl text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:col-span-7">
      Want product news and updates? Sign up for our newsletter.
    </h2>
    <form class="w-full max-w-md lg:col-span-5 lg:pt-2">
      <div class="flex gap-x-4">
        <label for="email-address" class="sr-only">Email address</label>
        <input id="email-address" type="email" name="email" required placeholder="Enter your email" autocomplete="email" class="min-w-0 flex-auto rounded-md bg-white/10 px-3.5 py-2 text-base text-white outline-1 -outline-offset-1 outline-white/10 placeholder:text-white/75 focus:outline-2 focus:-outline-offset-2 focus:outline-white sm:text-sm/6" />
        <button type="submit" class="flex-none rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold text-sky-500 shadow-xs hover:bg-sky-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">Subscribe</button>
      </div>
      <p class="mt-4 text-sm/6 text-white">
        We care about your data. Read our 
        <%= link_to "Privacy policy", privacy_path, class: "text-sm/6 font-semibold text-gray-200 hover:text-gray-50" %>.
      </p>
    </form>
  </div>
</div>
