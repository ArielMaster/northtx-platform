<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-base/7 font-semibold text-sky-500">Guides</h1>
      <p class="mt-2 text-5xl font-semibold tracking-tight text-gray-900 sm:text-6xl">
        Step-by-step guides to help you succeed
      </p>
      <p class="mt-6 text-lg font-medium text-gray-600 sm:text-xl/8">
        Explore practical tutorials and walkthroughs designed to help you get the most out of the platform — from setup to advanced workflows.
      </p>
    </div>
  </div>
</div>

<div class="bg-white pb-16 sm:pb-24">
  <div class="mx-auto max-w-3xl px-6 lg:px-8">
    <div class="relative">
      <input
        type="text"
        placeholder="Search guides..."
        class="w-full rounded-xl border border-gray-300 px-4 py-3 text-base text-gray-900 shadow-sm focus:border-sky-500 focus:ring-2 focus:ring-sky-500"
      />
      <svg class="absolute right-4 top-3.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 1 0 5.65 5.65a7.5 7.5 0 0 0 10.6 10.6Z" />
      </svg>
    </div>
  </div>
</div>

<div class="bg-gray-50 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <div class="mx-auto max-w-3xl text-center">
      <p class="text-base/7 font-semibold text-sky-500">Browse guides</p>
      <h2 class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">
        Explore by category
      </h2>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-10 md:grid-cols-2 lg:grid-cols-3">

      <!-- Card -->
      <%= link_to "#", class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Getting Started</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Learn the basics and set up your account in minutes.
        </p>
      <% end %>

      <!-- Card -->
      <%= link_to "#", class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Building Websites</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Step-by-step tutorials for creating and customizing websites.
        </p>
      <% end %>

      <!-- Card -->
      <%= link_to "#", class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Forms & Submissions</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Learn how to create forms, manage submissions, and automate workflows.
        </p>
      <% end %>

      <!-- Card -->
      <%= link_to "#", class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Analytics</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Understand your data and make informed decisions.
        </p>
      <% end %>

      <!-- Card -->
      <%= link_to "#", class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Automation</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Build powerful workflows that run automatically.
        </p>
      <% end %>

      <!-- Card -->
      <%= link_to "#", class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Commerce</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Set up products, payments, and subscriptions.
        </p>
      <% end %>

    </div>

  </div>
</div>

<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <div class="mx-auto max-w-3xl text-center">
      <p class="text-base/7 font-semibold text-sky-500">Featured</p>
      <h2 class="mt-2 text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">
        Popular guides
      </h2>
    </div>

    <div class="mt-16 space-y-8">

      <%= link_to "#", class: "block rounded-3xl bg-gray-50 p-8 ring-1 ring-gray-200 hover:shadow-md transition" do %>
        <h3 class="text-xl font-semibold text-gray-900">How to create your first website</h3>
        <p class="mt-3 text-base/7 text-gray-600">
          A complete walkthrough for building and publishing your first site.
        </p>
      <% end %>

      <%= link_to "#", class: "block rounded-3xl bg-gray-50 p-8 ring-1 ring-gray-200 hover:shadow-md transition" do %>
        <h3 class="text-xl font-semibold text-gray-900">Setting up OAuth providers</h3>
        <p class="mt-3 text-base/7 text-gray-600">
          Learn how to integrate Apple, Google, LinkedIn, Facebook, and more.
        </p>
      <% end %>

      <%= link_to "#", class: "block rounded-3xl bg-gray-50 p-8 ring-1 ring-gray-200 hover:shadow-md transition" do %>
        <h3 class="text-xl font-semibold text-gray-900">Building your first automation</h3>
        <p class="mt-3 text-base/7 text-gray-600">
          Create a workflow that triggers on form submissions and sends notifications.
        </p>
      <% end %>

    </div>

  </div>
</div>

<div class="bg-sky-500 py-16 sm:py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-10">
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:col-span-7">
      Need help finding the right guide? We're here to assist.
    </h2>

    <div class="lg:col-span-5 lg:pt-2">
      <%= link_to "Submit a ticket", submit_ticket_path,
        class: "inline-flex items-center justify-center rounded-md bg-white px-4 py-2.5 text-sm font-semibold text-sky-500 shadow-xs hover:bg-sky-100 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white" %>
    </div>
  </div>
</div>
