        <p class="mt-4 text-sm/6 text-gray-600">
          Browse guides, tutorials, and API references.
        </p>
      <% end %>

      <%= link_to guides_path, class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Guides</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Step-by-step instructions for common tasks.
        </p>
      <% end %>

      <%= link_to contact_path, class: "rounded-3xl bg-white p-8 ring-1 ring-gray-200 hover:shadow-md transition block" do %>
        <h3 class="text-lg font-semibold text-gray-900">Contact us</h3>
        <p class="mt-4 text-sm/6 text-gray-600">
          Prefer direct communication? Reach out anytime.
        </p>
      <% end %>

    </div>

  </div>
</div>

<div class="bg-sky-500 py-16 sm:py-24 lg:py-32">
