<!-- app/views/receipts/show.html.erb -->
<div class="mx-auto max-w-2xl py-16 px-6">
  <h1 class="text-2xl font-semibold text-gray-900">Receipt</h1>
  <p class="mt-2 text-sm text-gray-600">
    Receipt ID: <%= @receipt.id %><br>
    Date: <%= @receipt.created_at.to_s(:long) %>
  </p>

  <div class="mt-8 border-t border-gray-200 pt-6 space-y-4">
    <p><strong>Name:</strong> <%= @user.name %></p>
    <p><strong>Email:</strong> <%= @user.email %></p>
    <p><strong>Plan:</strong> <%= @plan.name %></p>
    <p><strong>Amount:</strong> $<%= (@receipt.amount_cents / 100.0).round(2) %> <%= @receipt.currency.upcase %></p>
  </div>

  <div class="mt-8">
    <%= link_to "Download PDF",
                receipt_path(@receipt, format: :pdf),
                class: "inline-flex items-center rounded-md bg-sky-500 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-400" %>
  </div>
</div>
