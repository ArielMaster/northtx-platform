<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "NORTHTX | Secure Web Applications Development" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Northtx V2 5">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/logo.png" type="image/png">
    <link rel="icon" href="/icon.png" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "pages/header" %>
      <% if notice.present? %>
        <div class="flex justify-center">
          <p class="notice absolute mx-auto w-fit text-green-700 px-8 py-2 bg-green-100 rounded-sm border border-green-700"><%= notice %></p>
        </div>
      <% elsif alert.present? %>
        <div class="flex justify-center">    
          <p class="alert absolute mx-auto w-fit text-red-700 px-8 py-2 bg-red-100 rounded-sm border border-red-700"><%= alert %></p>
        </div>
      <% end %>
    <!--main class="container mx-auto mt-28 px-5 flex"-->
      <%= yield %>
    <!--/main-->
    <%= render "pages/footer" %>
  </body>
  <% unless @cookie_consent %>
    <div data-controller="consent"
     data-consent-target="banner"
     class="animate-fadeSlideIn fixed inset-x-0 bottom-0 flex flex-col justify-between gap-x-8 gap-y-4 border-t border-gray-900/10 bg-white p-6 shadow-lg md:flex-row md:items-center lg:px-8 transition-all overflow-hidden">

      <p class="max-w-4xl text-sm/6 text-gray-900">
        This website uses browser cookies to improve functionality, analyze traffic, and enhance your experience. Accepting cookies is optional.
        See our <%= link_to "cookie policy", cookie_policy_path, class: "font-semibold text-sky-500 hover:text-sky-400" %>.
      </p>

      <div class="flex flex-none items-center gap-x-5">
        <button
          data-action="click->consent#accept"
          class="rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-sky-500">
          Accept all
        </button>

        <button
          data-action="click->consent#reject"
          class="text-sm/6 font-semibold text-gray-900 hover:text-sky-500">
          Reject all
        </button>
      </div>
    </div>
  <% end %>
  <!--div class="fixed inset-x-0 bottom-0 flex flex-col justify-between gap-x-8 gap-y-4 border-t border-gray-900/10 bg-white p-6 shadow-lg md:flex-row md:items-center lg:px-8">
    <p class="max-w-4xl text-sm/6 text-gray-900">This website uses cookies to supplement a balanced diet and provide a much deserved reward to the senses after consuming bland but nutritious meals. Accepting our cookies is optional but recommended, as they are delicious. See our <!%= link_to "cookie policy", cookie_policy_path, class: "font-semibold text-blue-600 hover:text-blue-500" %>.</p>
    <div class="flex flex-none items-center gap-x-5">
      <button type="button" class="rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-gray-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900">Accept all</button>
      <button type="button" class="text-sm/6 font-semibold text-gray-900 hover:text-gray-700">Reject all</button>
    </div>
  </div-->
</html>
