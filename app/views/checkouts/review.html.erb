<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-3xl px-6 lg:px-8">
    <h1 class="text-3xl font-semibold text-gray-900">Review your order</h1>

    <div class="mt-6 space-y-4">
      <p><strong>Plan:</strong> <%= @plan.name %></p>
      <p><strong>Price:</strong> $<%= (@plan.price_cents / 100.0).round(2) %> / <%= @plan.interval %></p>
      <p><strong>Name:</strong> <%= session.dig(:checkout, "name") %></p>
      <p><strong>Email:</strong> <%= session.dig(:checkout, "email") %></p>
      <p><strong>Phone:</strong> <%= session.dig(:checkout, "phone") %></p>
      <dt class="font-medium">Terms Accepted</dt>
        <dd>
          <% if session[:checkout]["terms_accepted"] %>
            <span class="text-green-600 font-semibold">Yes</span>
          <% else %>
            <span class="text-red-600 font-semibold">No</span>
          <% end %>
        </dd>
    </div>
    <div class="mt-4">
      <h3 class="font-medium text-gray-900">Included Features</h3>
      <pre class="mt-2 whitespace-pre-wrap text-sm text-gray-700"><i><%= @plan.features %></i></pre>
    </div>



    <%= form_with url: create_session_checkouts_path,
              method: :post,
              data: { turbo: false },
              class: "mt-8" do |f| %>

      <%= f.submit "Pay now",
        class: "w-full rounded-md bg-sky-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-sky-400" %>
    <% end %>

  </div>
</div>
