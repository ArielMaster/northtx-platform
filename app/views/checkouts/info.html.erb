<div class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-3xl px-6 lg:px-8">
    <h1 class="text-3xl font-semibold text-gray-900">Checkout - Your details</h1>
    <p class="mt-2 text-gray-600">
      Plan: <%= @plan.name %> - $<%= (@plan.price_cents / 100.0).round(2) %> / <%= @plan.interval %>
    </p>

    <%= form_with url: info_submit_checkouts_path, method: :post, class: "mt-8 space-y-6" do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-900">Full name</label>
        <%= f.text_field :name,
              required: true,
              class: "mt-2 w-full rounded-md border border-gray-300 px-3 py-2" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-900">Email</label>
        <%= f.email_field :email,
              required: true,
              class: "mt-2 w-full rounded-md border border-gray-300 px-3 py-2" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-900">Phone</label>
        <%= f.telephone_field :phone,
              class: "mt-2 w-full rounded-md border border-gray-300 px-3 py-2" %>
      </div>

      <div>
        <%= f.submit "Next",
              class: "w-full rounded-md bg-sky-500 px-4 py-2.5 text-sm font-semibold text-white hover:bg-sky-400" %>
      </div>
    <% end %>
  </div>
</div>
