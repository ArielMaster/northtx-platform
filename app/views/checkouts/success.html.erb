<!-- 1. Confirmation Hero -->
<div class="mx-auto max-w-2xl py-20 text-center">
  <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
    <svg class="h-10 w-10 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
  </div>
<% if @receipt.present? %>
  <h1 class="mt-6 text-3xl font-semibold text-gray-900">
    Payment Successful
  </h1>

  <p class="mt-2 text-gray-600">
    Thank you for your purchase. Your subscription is now active.
  </p>
</div>


<!-- 2. RECEIPT SUMMARY CARD (THIS IS THE SECTION YOU ASKED ABOUT) -->
<div class="mx-auto max-w-2xl rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
  <h2 class="text-lg font-semibold text-gray-900">Order Summary</h2>

  <dl class="mt-6 space-y-4">
    <div class="flex justify-between">
      <dt class="text-gray-600">Plan</dt>
      <dd class="font-medium text-gray-900"><%= @receipt.plan_name %></dd>
    </div>

    <div class="flex justify-between">
      <dt class="text-gray-600">Amount Paid</dt>
      <dd class="font-medium text-gray-900">$<%= @receipt.amount_cents / 100.0 %></dd>
    </div>


    <div class="flex justify-between">
      <dt class="text-gray-600">Customer</dt>
      <dd class="font-medium text-gray-900"><%= @receipt.name %></dd>
    </div>

    <div class="flex justify-between">
      <dt class="text-gray-600">Email</dt>
      <dd class="font-medium text-gray-900"><%= @receipt.email %></dd>
    </div>

    <div class="flex justify-between">
      <dt class="text-gray-600">Receipt ID</dt>
      <dd class="font-medium text-gray-900"><%= @receipt.stripe_session_id %></dd>
    </div>
  </dl>
</div>

<!-- 3. Call to Action -->
<div class="mx-auto mt-10 max-w-2xl text-center">
  <%= link_to "Home",
      root_path,
      class: "inline-flex items-center rounded-md bg-sky-500 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-400" %>

  <p class="mt-4 text-gray-500">
    A receipt has been emailed to you.
  </p>
<% else %>
  <p class="text-center text-gray-600">Receipt not found.</p>
<% end %>
</div>
